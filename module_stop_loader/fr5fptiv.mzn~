std::optional<std::pair<void*,uint64_t>> GetRelocVA(PVOID imageBase)
{
    auto dos = (IMAGE_DOS_HEADER*)imageBase;
    if (dos->e_magic != IMAGE_DOS_SIGNATURE)
        return {};

    auto nt = (IMAGE_NT_HEADERS*)((BYTE*)imageBase + dos->e_lfanew);
    if (nt->Signature != IMAGE_NT_SIGNATURE)
        return {};

    auto section = IMAGE_FIRST_SECTION(nt);
    WORD number = nt->FileHeader.NumberOfSections;

    for (int i = 0; i < number; ++i)
    {
        // 判断节名是否为 ".reloc"
        if (memcmp(section[i].Name, ".text", 6) == 0)
        {
            // 映射后的 VA = imageBase + VirtualAddress
            return std::make_pair((BYTE*)imageBase + section[i].VirtualAddress, section[i].Misc.VirtualSize);
        }
    }
    return {};
}
